# ─── ppmagent configuration ───────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is git-ignored.

# ── Model provider (pi) ──
# Which LLM provider to use. One of: anthropic | deepseek | zai | openrouter
# (aliases: glm/zhipu = zai). Default: anthropic
PPMA_PROVIDER=anthropic
# Set the API key for the provider you selected above. Only the selected
# provider's key is required.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
ZAI_API_KEY=
OPENROUTER_API_KEY=
# Optional model override. If unset, a per-provider default is used:
#   anthropic  -> claude-sonnet-4-6
#   deepseek   -> deepseek-v4-pro
#   zai (glm)  -> glm-4.7
#   openrouter -> anthropic/claude-sonnet-4.6
PPMA_MODEL=claude-sonnet-4-6

# ── Memory layer (ppm CLI) ──
# Path to the `ppm` binary. If empty, it must be on PATH.
PPMA_PPM_BIN=ppm
# Memory workspace root. Passed to every `ppm` call as --root.
PPM_MEMORY_ROOT=./memory
# How many recent decisions `ppm context` injects each turn.
PPMA_CONTEXT_RECENT=3

# ── Tracker layer (DataboxPPM via dbxcli) ──
# Path to the `dbxcli` binary.
PPMA_DBXCLI_BIN=dbxcli
# dbxcli config file (DataboxPPM endpoint + auth). It also carries the dataset
# and action aliases, so the agent discovers those at runtime (via `dbxcli
# datasets` / `dbxcli action list`) — no per-entity env vars needed.
PPMA_DBXCLI_CONFIG=

# ── Telegram adapter ──
# Bot token from @BotFather.
PPMA_TELEGRAM_BOT_TOKEN=
# REQUIRED: the single chat id the bot answers to (single-tenant PoC). The bot
# fails to start without it — it can create tracker issues, dispatch coding
# agents, and push code, so it must not be open to whoever finds the handle.
# Group chat ids are negative. To explicitly run open to ALL chats instead,
# leave this empty and set PPMA_ALLOW_ANY_CHAT=true.
PPMA_TELEGRAM_ALLOWED_CHAT_ID=
# Durable session location (transcript + active project; survives restarts). Its
# directory is the session store: each session is a JSON file under sessions/
# with a `current` pointer, so /new, /resume, etc. can manage multiple sessions.
PPMA_SESSION_FILE=./.session/session.json

# ── Compaction ──
# Token threshold above which the session compacts. 0 = use pi defaults.
PPMA_COMPACTION_TOKEN_THRESHOLD=0

# ── Confirmation gate ──
# Whether mutating operations (tracker create/update, git push/PR) require
# explicit user confirmation before executing. Default: true (gate enabled).
# Set to false to disable — intended for automated PO agents running without a
# human in the loop (e.g. CI pipelines, background scheduler agents).
PPMA_CONFIRMATION_GATE=true

# ── Logging (loglayer) ──
# Minimum severity emitted: trace|debug|info|warn|error|fatal. Default: info
PPMA_LOG_LEVEL=debug
# Output shape: `json` (one object per line, for shippers) or `pretty` (readable
# console for local dev). Default: json
PPMA_LOG_FORMAT=json

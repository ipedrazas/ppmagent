# ─── ppmagent configuration ───────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is git-ignored.

# ── Model provider (pi) ──
# Which LLM provider to use. One of: anthropic | deepseek | zai | openrouter
# (aliases: glm/zhipu = zai). Default: anthropic
PPMA_PROVIDER=anthropic
# Set the API key for the provider you selected above. Only the selected
# provider's key is required.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
ZAI_API_KEY=
OPENROUTER_API_KEY=
# Optional model override. If unset, a per-provider default is used:
#   anthropic  -> claude-sonnet-4-6
#   deepseek   -> deepseek-v4-pro
#   zai (glm)  -> glm-4.7
#   openrouter -> anthropic/claude-sonnet-4.6
PPMA_MODEL=claude-sonnet-4-6

# ── Memory layer (ppm CLI) ──
# Path to the `ppm` binary. If empty, it must be on PATH.
PPMA_PPM_BIN=ppm
# Memory workspace root. Passed to every `ppm` call as --root.
PPM_MEMORY_ROOT=./memory
# How many recent decisions `ppm context` injects each turn.
PPMA_CONTEXT_RECENT=3

# ── Tracker layer (DataboxPPM via dbxcli) ──
# Path to the `dbxcli` binary.
PPMA_DBXCLI_BIN=dbxcli
# dbxcli config file (DataboxPPM endpoint + auth). It also carries the dataset
# and action aliases, so the agent discovers those at runtime (via `dbxcli
# datasets` / `dbxcli action list`) — no per-entity env vars needed.
PPMA_DBXCLI_CONFIG=

# ── Telegram adapter ──
# Bot token from @BotFather.
PPMA_TELEGRAM_BOT_TOKEN=
# REQUIRED: the single chat id the bot answers to (single-tenant PoC). The bot
# fails to start without it — it can create tracker issues, dispatch coding
# agents, and push code, so it must not be open to whoever finds the handle.
# Group chat ids are negative. To explicitly run open to ALL chats instead,
# leave this empty and set PPMA_ALLOW_ANY_CHAT=true.
PPMA_TELEGRAM_ALLOWED_CHAT_ID=
# Durable session location (transcript + active project; survives restarts). Its
# directory is the session store: each session is a JSON file under sessions/
# with a `current` pointer, so /new, /resume, etc. can manage multiple sessions.
PPMA_SESSION_FILE=./.session/session.json

# ── Compaction ──
# Token threshold above which the session compacts. 0 = use pi defaults.
PPMA_COMPACTION_TOKEN_THRESHOLD=0

# ── Confirmation gate ──
# Whether mutating operations (tracker create/update, git push/PR) require
# explicit user confirmation before executing. Default: true (gate enabled).
# Set to false to disable — intended for automated PO agents running without a
# human in the loop (e.g. CI pipelines, background scheduler agents).
PPMA_CONFIRMATION_GATE=true
# ── GitHub (gh CLI authentication for ProteOS machines) ──
# GitHub Personal Access Token (or GitHub App installation token) with `repo`
# scope. Forwarded to the `proteos` CLI so that `gh` is authenticated on ProteOS
# machines. Required for `proteos_git_pr` and for headless coding agents to run
# `gh pr create`. Without it git push still works (deploy keys), but PR creation
# fails. Never hardcode a token — pass it via environment or secret management.
GITHUB_TOKEN=

# ── GitHub webhook (PR notifications) ──
# HTTP port for the webhook server. Unset = disabled.
PPMA_GITHUB_WEBHOOK_PORT=
# HMAC-SHA256 secret from the GitHub webhook settings page. Unset = no signature
# verification (only acceptable in dev / behind a firewall).
PPMA_GITHUB_WEBHOOK_SECRET=
# Comma-separated repo patterns to monitor. Supports owner/* wildcards.
# Example: tavon-ai/*,ipedrazas/*
PPMA_GITHUB_MONITORED_REPOS=tavon-ai/*,ipedrazas/*

# ── Session retention ──
# Number of days after which an idle session is deleted by the background
# retention runner. 0 = disabled (sessions accumulate indefinitely). Default: 30.
# The currently active session is never deleted regardless of this setting.
PPMA_SESSION_RETENTION_DAYS=30

# ── Telegram webhook transport (scaling alternative to long-polling) ──
# Set BOTH vars to activate webhook mode. When active, Telegram POSTs updates
# to your public URL and the long-poll loop is disabled. See
# src/telegram/webhook-transport.ts for the scaling rationale and trade-offs.
# Requires a public HTTPS URL (a reverse proxy like nginx or Caddy terminating
# TLS in front of this port works well).
#
# HTTP port the webhook server listens on. Unset = polling mode (default).
PPMA_TELEGRAM_WEBHOOK_PORT=
# Public HTTPS URL Telegram will POST to (must end with /webhook/telegram).
# Example: https://bot.example.com/webhook/telegram
PPMA_TELEGRAM_WEBHOOK_URL=
# Optional secret token for X-Telegram-Bot-Api-Secret-Token header validation.
# Strongly recommended in production — proves the POST is from Telegram.
PPMA_TELEGRAM_WEBHOOK_SECRET=

# ── Logging (loglayer) ──
# Minimum severity emitted: trace|debug|info|warn|error|fatal. Default: info
PPMA_LOG_LEVEL=debug
# Output shape: `json` (one object per line, for shippers) or `pretty` (readable
# console for local dev). Default: json
PPMA_LOG_FORMAT=json
